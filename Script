UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if clickToSelectEnabled and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        local mouse = LocalPlayer:GetMouse()
        local target = mouse.Target
        if target and target:IsA("BasePart") then
            local logMsg = string.format("-- PART\n%s", target:GetFullName())
            addLog(logMsg, "SELECT")
            task.spawn(function()
                local highlight = Instance.new("Highlight")
                highlight.FillColor = Theme.Accent
                highlight.OutlineColor = Theme.Success
                highlight.FillTransparency = 0.4
                highlight.OutlineTransparency = 0
                highlight.Adornee = target
                highlight.Parent = ScreenGui
                task.wait(1.5)
                highlight:Destroy()
            end)
        end
    end
end)

