-- --- TOUCH INTEREST DETECTOR ---
local function hookTouchInterest(p)
    if p:IsA("BasePart") then
        p.Touched:Connect(function(hit)
            if not touchInterestLoggingEnabled then return end
            local char = LocalPlayer.Character
            if not char or not hit:IsDescendantOf(char) then return end
            local pPath = p:GetFullName()
            if loggedTouchParts[pPath] and tick() - loggedTouchParts[pPath] < TOUCH_COOLDOWN then return end
            loggedTouchParts[pPath] = tick()
            local logMsg = string.format("-- TOUCH INTEREST\nPart: %s\nTouched by: %s", pPath, hit.Name)
            addLog(logMsg, "TOUCH")
        end)
    end
end

for _, item in ipairs(workspace:GetDescendants()) do
    hookTouchInterest(item)
end
workspace.DescendantAdded:Connect(hookTouchInterest)

