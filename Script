-- --- HELPER FUNCTIONS ---
local function getFormattedPath(instance)
    local parts = {}
    local current = instance
    while current and current ~= playerGui and current ~= game do
        table.insert(parts, 1, current.Name)
        current = current.Parent
    end
    return table.concat(parts, ".")
end

local function serializeTable(val, indent)
    indent = indent or 1
    local tabs = string.rep("\t", indent)
    local prevTabs = string.rep("\t", indent - 1)
    if type(val) == "table" then
        local res = "{\n"
        local keys = {}
        for k in pairs(val) do table.insert(keys, k) end
        for i, k in ipairs(keys) do
            local keyStr = (type(k) == "string") and k .. " = " or (type(k) == "number" and k ~= i and "[" .. tostring(k) .. "] = " or "")
            res = res .. tabs .. keyStr .. serializeTable(val[k], indent + 1) .. (i == #keys and "" or ",") .. "\n"
        end
        return res .. prevTabs .. "}"
    elseif type(val) == "string" then
        return '"' .. val .. '"'
    elseif type(val) == "Instance" then
        return "game." .. val:GetFullName()
    else
        return tostring(val)
    end
end

local function applyFilters(text)
    local processed = text
    if filterUsername and LocalPlayer then
        processed = string.gsub(processed, LocalPlayer.Name, 'game:GetService("Players").LocalPlayer.Name')
    end
    return processed
end

local function updateLogs()
    local searchText = SearchBox.Text:lower()
    for _, data in pairs(logs) do
        local text = showTimestamp and (data.time .. data.msg) or data.msg
        local filteredText = applyFilters(text)
        data.label.Text = filteredText
        data.label.Visible = (searchText == "" or string.find(filteredText:lower(), searchText))
    end
end

local function addLog(message, messageType)
    local timestamp = "[" .. os.date("%X") .. "] "
    local cleanMsg = tostring(message)
    local btn = Instance.new("TextButton", LogScroll)
    btn.Size = UDim2.new(1, 0, 0, 20)
    btn.AutomaticSize = Enum.AutomaticSize.Y
    btn.BackgroundTransparency = 1
    btn.Font = Enum.Font.Code
    btn.TextSize = 12
    btn.TextXAlignment = Enum.TextXAlignment.Left

    -- COLOR LOGIC
    local defaultColor = Color3.fromRGB(220, 220, 225)
    if messageType == "REMOTE" then
        defaultColor = Color3.fromRGB(52, 152, 219)
    elseif messageType == "PROXIMITY" then
        defaultColor = Color3.fromRGB(230, 126, 34)
    elseif messageType == "UICLICK" then
        defaultColor = Color3.fromRGB(155, 89, 182)
    elseif messageType == "TOUCH" then
        defaultColor = Color3.fromRGB(26, 188, 156)
    elseif messageType == "CLICKDETECTOR" then
        defaultColor = Color3.fromRGB(255, 118, 117)
    elseif messageType == "SELECT" then
        defaultColor = Color3.fromRGB(241, 196, 15)
    elseif messageType == "SYSTEM" then
        defaultColor = Theme.Success
    elseif messageType == Enum.MessageType.MessageError then
        defaultColor = Theme.Danger
    elseif messageType == Enum.MessageType.MessageWarning then
        defaultColor = Color3.fromRGB(241, 196, 15)
    end

    btn.TextColor3 = defaultColor
    btn.TextWrapped = true
    local finalMsg = showTimestamp and (timestamp .. cleanMsg) or cleanMsg
    local filteredFinal = applyFilters(finalMsg)
    btn.Text = filteredFinal
    table.insert(logs, {label = btn, time = timestamp, msg = cleanMsg, color = defaultColor})

    if autoCopyEnabled and setclipboard then
        local full = ""
        for _, v in pairs(logs) do
            if v.label.Visible then full = full .. v.label.Text .. "\n" end
        end
        setclipboard(full)
    end

    local lastClick = 0
    btn.MouseButton1Down:Connect(function()
        local now = tick()
        if now - lastClick < 0.4 and setclipboard then
            setclipboard(applyFilters(cleanMsg))
            btn.TextColor3 = Theme.Success
            task.wait(0.2)
            btn.TextColor3 = defaultColor
        end
        lastClick = now
    end)
end

