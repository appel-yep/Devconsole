if hookmetamethod then
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if remoteLoggingEnabled and not checkcaller() and (method == "FireServer" or method == "InvokeServer") then
            local args = {...}
            task.spawn(function()
                local pathParts = self:GetFullName():split(".")
                local formattedPath = 'game:GetService("' .. pathParts[1] .. '")'
                for i = 2, #pathParts do
                    formattedPath = formattedPath .. ':WaitForChild("' .. pathParts[i] .. '")'
                end
                addLog(string.format("-- REMOTE EVENT\nPath: %s\nMethod: %s\nArgs: %s", formattedPath, method, serializeTable(args)), "REMOTE")
            end)
        end
        return oldNamecall(self, ...)
    end)
end

